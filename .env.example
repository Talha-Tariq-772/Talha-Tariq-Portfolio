MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=portfolio
MONGODB_COLLECTION=incomming
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,https://talhatariq.online,https://www.talhatariq.online

# Used by the frontend to reach the API
VITE_API_BASE_URL=http://localhost:5000
# Used by runtime SEO metadata and canonical tags (set in Vercel production)
VITE_SITE_URL=https://talhatariq.online
# In production you can leave this unset to default to the current site origin
# (recommended so www/non-www domains avoid redirects), or override with your API host
# e.g. https://www.talhatariq.online

# Email notifications via Resend
RESEND_API_KEY=your_key_here
FROM_EMAIL="Portfolio Contact <onboarding@resend.dev>"
RECEIVER_EMAIL=tariqtalha772@gmail.com

# Optional: powers the portfolio AI chatbot with Google Gemini.
# If unset, chatbot still works using the built-in intelligent fallback.
GEMINI_API_KEY=your_key_here
# Also supported: GOOGLE_API_KEY or GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash
